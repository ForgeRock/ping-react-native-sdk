{
  "name": "@react-native-pingidentity/journey-poc",
  "version": "0.1.0",
  "description": "Ping Identity Journey POC TurboModule",
  "main": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec"
  ],
  "scripts": {
    "codegen": "yarn @react-native/codegen --config ./codegenConfig.json",
    "build": "bob build",
    "clean": "rimraf lib"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "react-native-builder-bob": "^0.40.15",
    "typescript": "^5.9.2"
  },
  "license": "MIT",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNPingJourneyPOCSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativepingidentity.journeypoc"
    }
  }
}
