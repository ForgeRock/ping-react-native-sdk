{
  "name": "@ping-identity/rn-external-idp",
  "version": "1.0.0-beta.0",
  "description": "Ping Identity External IDP library for React Native, enabling seamless authentication with external identity providers.",
  "homepage": "https://www.pingidentity.com/",
  "license": "MIT",
  "author": "Ping Identity",
  "main": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec"
  ],
  "scripts": {
    "codegen": "yarn @react-native/codegen --config ./codegenConfig.json",
    "build": "bob build",
    "test": "jest",
    "clean": "rimraf lib",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --no-config-lookup --config ../../eslint.config.mjs \"src/**/*.{js,jsx,ts,tsx}\"",
    "prettier": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\" README.md babel.config.js jest.config.js eslint.config.mjs"
  },
  "dependencies": {
    "@ping-identity/rn-core": "workspace:*",
    "@ping-identity/rn-types": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "react-native-builder-bob": "^0.40.14",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.9.2"
  },
  "codegenConfig": {
    "name": "RNPingExternalIdpSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.pingidentity.rnexternalidp"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
