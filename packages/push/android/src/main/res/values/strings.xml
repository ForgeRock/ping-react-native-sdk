<!--
  Default string resources for RNPingPushMessagingService system tray notifications.

  Override any of these in your app's res/values/strings.xml to customise
  the text shown when a push authentication request arrives while the app
  is backgrounded or killed.

  Example override:
      <string name="ping_push_notification_title">Acme Corp — Authentication Request</string>
      <string name="ping_push_notification_body">Someone is trying to sign in to your account</string>
      <string name="ping_push_channel_name">Acme Authentication</string>
      <string name="ping_push_channel_description">Acme Corp push authentication requests</string>
-->
<resources>
    <string name="ping_push_notification_title">Authentication Request</string>
    <string name="ping_push_notification_body">You have a new authentication request</string>
    <string name="ping_push_channel_name">Push Authentication</string>
    <string name="ping_push_channel_description">Ping Identity push authentication requests</string>
</resources>
