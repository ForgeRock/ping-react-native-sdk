{
  "name": "@ping-identity/rn-journey",
  "version": "0.1.0",
  "description": "Ping Identity Journey for React Native",
  "homepage": "https://www.pingidentity.com/",
  "author": "Ping Identity",
  "main": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec"
  ],
  "scripts": {
    "codegen": "yarn @react-native/codegen --config ./codegenConfig.json",
    "build": "bob build",
    "test": "jest",
    "clean": "rimraf lib"
  },
  "dependencies": {
    "@ping-identity/rn-core": "workspace:*",
    "@ping-identity/rn-types": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "react-native-builder-bob": "^0.40.14",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.9.2"
  },
  "license": "MIT",
  "codegenConfig": {
    "name": "RNPingJourneySpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.pingidentity.rnjourney"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
