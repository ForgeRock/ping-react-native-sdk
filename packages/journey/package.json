{
  "name": "@react-native-pingidentity/journey",
  "version": "0.1.0",
  "description": "Ping Identity Journey TurboModule for React Native",
  "main": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec"
  ],
  "scripts": {
    "codegen": "react-native-codegen --config ./codegenConfig.json",
    "build": "bob build",
    "clean": "rimraf lib"
  },
  "peerDependencies": {
    "@react-native-pingidentity/storage": "*",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "react-native-builder-bob": "^0.40.14",
    "typescript": "^5.9.2"
  },
  "license": "MIT",
  "codegenConfig": {
    "name": "RNPingJourneySpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativepingidentity.journey"
    }
  }
}
