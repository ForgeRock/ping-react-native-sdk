# PingTestRunner E2E config
# Copy to .env and fill in values before running E2E tests.

# Journey / server config
PING_SERVER_URL=https://your-server.example.com/am
PING_REALM_PATH=/alpha
PING_COOKIE_NAME=iPlanetDirectoryPro
PING_JOURNEY_NAME=Login

# OIDC config
PING_DISCOVERY_ENDPOINT=https://your-server.example.com/am/oauth2/alpha/.well-known/openid-configuration
PING_CLIENT_ID=your-client-id
PING_REDIRECT_URI=org.forgerock.demo://oauth2redirect

# Test credentials (required for Tier 2 live tests)
PING_TEST_USERNAME=your-test-username
PING_TEST_PASSWORD=your-test-password
