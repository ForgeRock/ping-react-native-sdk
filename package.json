{
  "private": true,
  "name": "react-native-pingidentity",
  "version": "0.0.1",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "packages:install": "yarn install",
    "packages:build": "yarn workspaces foreach -A -t --topological-dev run build",
    "packages:info": "yarn workspaces info",
    "docs:browser": "typedoc --options typedoc.browser.json",
    "docs:oidc": "typedoc --options typedoc.oidc.json",
    "docs:generate": "typedoc --options typedoc.json",
    "packages:sample:build-install": "yarn packages:install && yarn packages:build && yarn sample:clean-install",
    "test:browser": "yarn workspace @ping-identity/rn-browser test",
    "test:oidc": "yarn workspace @ping-identity/rn-oidc test",
    "test:logger": "yarn workspace @react-native-pingidentity/logger test",
    "sample:clean-install": "yarn workspace PingSampleApp run clean-install",
    "sample:clean-android": "rm -rf PingSampleApp/android/app/build PingSampleApp/android/build PingSampleApp/android/.gradle && (rm -f ~/.gradle/wrapper/dists/gradle-8.14.1-bin/*/gradle-8.14.1-bin.zip.lck || true) && (cd PingSampleApp/android && ./gradlew clean)",
    "sample:run:ios": "yarn workspace PingSampleApp run ios",
    "sample:run:android": "yarn workspace PingSampleApp run android",
    "sample:restart:metro": "yarn workspace PingSampleApp run reset-cache",
    "storage:test": "yarn workspace @ping-identity/rn-storage run test"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "PingSampleApp"
    ]
  },
  "devDependencies": {
    "@react-native/codegen": "^0.82.1",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "typedoc": "^0.27.7"
  },
  "packageManager": "yarn@4.11.0"
}
