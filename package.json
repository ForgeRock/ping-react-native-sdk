{
  "private": true,
  "name": "react-native-pingidentity",
  "version": "0.0.1",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "packages:install": "yarn install",
    "packages:build": "yarn workspaces foreach -A -t --topological-dev run build",
    "packages:info": "yarn workspaces info",
    "docs:browser": "typedoc --options typedoc.browser.json",
    "packages:sample:build-install": "yarn packages:install && yarn packages:build && yarn sample:clean-install",
    "test:browser": "yarn workspace @react-native-pingidentity/browser test",
    "sample:clean-install": "yarn workspace PingSampleApp run clean-install",
    "sample:run:ios": "yarn workspace PingSampleApp run ios",
    "sample:run:android": "yarn workspace PingSampleApp run android",
    "sample:restart:metro": "yarn workspace PingSampleApp run reset-cache"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "PingSampleApp"
    ]
  },
  "devDependencies": {
    "@react-native/codegen": "^0.82.1",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "typedoc": "^0.27.7"
  },
  "packageManager": "yarn@4.11.0"
}
